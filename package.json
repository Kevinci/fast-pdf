{
  "name": "fast-pdf",
  "version": "0.5.0",
  "description": "Fast, dependency-free, direct-to-PDF generation for Node, Bun, Deno, browsers and edge runtimes.",
  "license": "MIT",
  "author": "Kevin Imig <kevinci.coding@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kevinci/fast-pdf.git"
  },
  "homepage": "https://kevinci.github.io/fast-pdf/",
  "bugs": {
    "url": "https://github.com/Kevinci/fast-pdf/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "fast-pdf-skill": "scripts/install-skill.mjs"
  },
  "files": [
    "dist",
    "examples/*.ts",
    "scripts/install-skill.mjs",
    ".claude/skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pdf",
    "pdf-generation",
    "typescript",
    "esm",
    "browser",
    "deno",
    "bun",
    "serverless",
    "edge",
    "invoice",
    "table"
  ],
  "scripts": {
    "build": "tsup",
    "prepare": "tsup",
    "prepublishOnly": "npm run typecheck && npm test && npm run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx bench/bench.ts",
    "example": "tsx examples/invoice.ts",
    "showcase": "tsx examples/showcase.ts",
    "report": "tsx examples/report.ts",
    "docs:demo": "tailwindcss -i docs/demo.input.css -o docs/demo.tw.css --minify && node docs/build-demo.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
