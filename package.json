{
  "name": "fast-pdf",
  "version": "0.2.0",
  "description": "Fast, dependency-free, direct-to-PDF generation for Node, Bun, Deno, browsers and edge runtimes.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kevinci/fast-pdf.git"
  },
  "homepage": "https://kevinci.github.io/fast-pdf/",
  "bugs": {
    "url": "https://github.com/Kevinci/fast-pdf/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "docs/ARCHITECTURE.md",
    "docs/ROADMAP.md",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "pdf",
    "pdf-generation",
    "typescript",
    "esm",
    "browser",
    "deno",
    "bun",
    "serverless",
    "edge",
    "invoice",
    "table"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "bench": "tsx bench/bench.ts",
    "example": "tsx examples/invoice.ts",
    "showcase": "tsx examples/showcase.ts",
    "docs:demo": "tailwindcss -i docs/demo.input.css -o docs/demo.tw.css --minify && node docs/build-demo.mjs"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.3",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.7",
    "tailwindcss": "^4.3.3",
    "tsup": "^8.5.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
